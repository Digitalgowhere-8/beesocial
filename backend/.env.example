# ============================================
#  BEESOCIAL - BACKEND ENVIRONMENT
# ============================================
# Copy this file to `.env` and fill in real values.
#  cp .env.example .env

# --------- SERVER ---------
NODE_ENV=development
PORT=5000
# Comma-separated list of exact allowed CORS origins (frontend URLs).
# In production, set this or FRONTEND_URL to your deployed frontend URL(s).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Optional comma-separated regex patterns for dynamic preview domains.
# Example: ^https://.*\.vercel\.app$,^https://.*\.azurestaticapps\.net$
CORS_ORIGIN_PATTERNS=

# --------- DATABASE (MongoDB) ---------
# Local Mongo:   mongodb://127.0.0.1:27017/beesocial
# Atlas cloud:   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/beesocial
MONGO_URI=mongodb://127.0.0.1:27017/beesocial

# --------- AUTH (JWT) ---------
# Generate a strong random secret: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=replace_me_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d
JWT_SESSION_DAYS=7
REALTIME_TOKEN_EXPIRES_IN=2m
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

# --------- SEED SUPER ADMIN ---------
# Used once on `npm run seed` to create the first super admin
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@digitalgowhere.com
SEED_ADMIN_PASSWORD=ChangeMe@123

# --------- CRON / AUTOMATION ---------
# Default: 7 AM India Standard Time (Asia/Kolkata).  IST = UTC+5:30.
# Cron format: "minute hour day-of-month month day-of-week"
CRON_SCHEDULE=0 7 * * *
CRON_TIMEZONE=Asia/Kolkata
# Set ENABLE_CRON=false to disable scheduled fetching (useful in dev)
ENABLE_CRON=true

ENABLE_USER_SCHEDULES=true
USER_SCHEDULE_CRON=*/10 * * * *
SCHEDULE_SCAN_LIMIT=200
SCHEDULE_BATCH_SIZE=20
SCHEDULE_STAGGER_MS=3000

# --------- SCRAPING ---------
# Request timeout in milliseconds
SCRAPE_TIMEOUT_MS=20000
# How many concurrent scraping requests at once
SCRAPE_CONCURRENCY=4
# Basic in-process protection against too many expensive jobs at once.
# For true multi-instance production, move this to a shared queue like Redis/BullMQ.
MAX_ACTIVE_FETCH_JOBS=6
MAX_ACTIVE_FETCH_JOBS_PER_TENANT=1
MAX_ACTIVE_BLOG_JOBS=8
MAX_ACTIVE_BLOG_JOBS_PER_TENANT=2
MAX_ACTIVE_SOCIAL_JOBS=8
MAX_ACTIVE_SOCIAL_JOBS_PER_TENANT=2
# User-Agent used in HTTP requests
SCRAPE_USER_AGENT=Mozilla/5.0 (compatible; BeeSocialBot/1.0)

# --------- RATE LIMITING ---------
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=200
EXPENSIVE_RATE_LIMIT_WINDOW_MS=60000
EXPENSIVE_RATE_LIMIT_MAX=30
ANALYTICS_RATE_LIMIT_WINDOW_MS=60000
ANALYTICS_RATE_LIMIT_MAX=300

# --------- TAVILY (Optional, for relevance + evergreen) ---------
# Get a free key from https://tavily.com  -> leave empty to skip Tavily
TAVILY_API_KEY= 
TAVILY_MAX_RESULTS=10
MAX_TAVILY_QUERY_LENGTH=380
MAX_SEARCH_VARIANTS_PER_TOPIC=9
BROAD_DISCOVERY_MAX_RESULTS=3
AI_RELEVANCE_MIN_SCORE=30
FETCH_TOPICS=news,govt,competitor,evergreen
DEFAULT_FETCH_COUNTRY=
DEFAULT_FETCH_CATEGORY=
DEFAULT_FETCH_LANGUAGE=en
DEFAULT_FETCH_TIMEZONE=Asia/Kolkata
GOVT_MIN_PUBLISHED_AT=2026-06-01T00:00:00.000Z

# --------- OPENAI (Optional, for AI summary + smart category) ---------
# Get a key from https://platform.openai.com -> leave empty to use rule-based fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BLOG_MODEL=gpt-4o-mini
OPENAI_LINKEDIN_MODEL=gpt-4o-mini
# Use AI for summary generation? (true/false)
OPENAI_USE_FOR_SUMMARY=false
# Use AI for category classification? (true/false)
OPENAI_USE_FOR_CATEGORY=false

# --------- EMAIL / NOTIFICATIONS ---------
RESEND_API_KEY=
EMAIL_FROM=no-reply@mail.beesocial.example.com
EMAIL_FROM_NAME=BeeSocial
EMAIL_REPLY_TO=info@digitalgowhere.com
EMAIL_BRAND_NAME=BeeSocial
EMAIL_BRAND_LOGO_URL=
# Public frontend URL(s), comma-separated. Also allowed by CORS.
FRONTEND_URL=http://localhost:5173
MAIL_SEND_CHUNK_SIZE=10

# --------- ANALYTICS / ESTIMATION ---------
AVG_AI_TOKENS_PER_RESULT=700
AVG_TOKENS_PER_BLOG=5000
AVG_TOKENS_PER_SOCIAL_POST=800
ANALYTICS_SALT=

# --------- DATA RETENTION ---------
USER_SOFT_DELETE_GRACE_DAYS=7
