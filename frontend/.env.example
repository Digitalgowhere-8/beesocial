# Frontend env (Vite). Keys MUST start with VITE_ to be exposed to the browser.
# Copy this file to `.env` and adjust if needed.
#  cp .env.example .env

# Base URL of the backend API.
# Leave blank when frontend and backend are served from the same origin/proxy as /api.
# For separate deployments, set this in the hosting provider.
# The app will append /api automatically if you provide only the backend origin.
# Examples:
# VITE_API_BASE_URL=https://your-backend.example.com/api
# VITE_API_BASE_URL=https://your-backend.example.com
VITE_API_BASE_URL=

# Optional: where the Vite proxy forwards /api requests to (default http://localhost:5000)
VITE_API_PROXY=http://localhost:5000
